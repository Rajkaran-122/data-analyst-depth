# -----------------------------------------------------------------------------
# Data Analyst Depth - Environment Configuration
# -----------------------------------------------------------------------------

# API Settings
PORT=8000
DEBUG=True

# Security
# In production, set this to a long random string
JWT_SECRET_KEY=dev-secret-key-change-in-production

# CORS
# Comma-separated list of allowed origins (e.g., https://my-app.vercel.app)
# Use "*" for development to allow all origins
CORS_ORIGINS=*

# Database (MongoDB)
# Format: mongodb://user:pass@host:port/dbname
MONGO_URL=mongodb://localhost:27017
DB_NAME=data_analyst

# AI Analysis (Gemini API)
# Get your key at https://aistudio.google.com/
GOOGLE_API_KEY=your_gemini_api_key_here

# Optional: Other LLM Providers
# OPENAI_API_KEY=your_openai_key_here
# ANTHROPIC_API_KEY=your_anthropic_key_here
